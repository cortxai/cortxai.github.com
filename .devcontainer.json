{
  "name": "jekyll-site",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.2",
  "appPort": ["0.0.0.0:4000:4000"],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll Preview",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bundle install",
  "postStartCommand": "bundle exec jekyll serve --host 0.0.0.0 --livereload 2>&1 | tee /tmp/jekyll.log &",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
